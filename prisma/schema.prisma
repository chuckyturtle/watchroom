generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  username          String    @unique
  password          String
  bio               String?
  avatarColor       String    @default("#6366f1")
  points            Int       @default(0)
  isVerified        Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sentRequests       Friendship[]        @relation("Requester")
  receivedRequests   Friendship[]        @relation("Addressee")
  playlists          Playlist[]
  publishedPlaylists PublishedPlaylist[]
  playlistVotes      PlaylistVote[]
  savedPlaylists     SavedPlaylist[]
}

model Playlist {
  id        String         @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PlaylistItem[]
  published PublishedPlaylist?
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  videoId    String
  platform   String   @default("youtube")
  title      String
  thumbnail  String   @default("")
  channel    String   @default("")
  position   Int      @default(0)
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model PublishedPlaylist {
  id          String   @id @default(cuid())
  playlistId  String   @unique
  userId      String
  name        String
  rating      Int      @default(0)
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlist Playlist               @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    PublishedPlaylistItem[]
  votes    PlaylistVote[]
  saves    SavedPlaylist[]
}

model PublishedPlaylistItem {
  id                  String @id @default(cuid())
  publishedPlaylistId String
  videoId             String
  platform            String @default("youtube")
  title               String
  thumbnail           String @default("")
  channel             String @default("")
  position            Int    @default(0)

  publishedPlaylist PublishedPlaylist @relation(fields: [publishedPlaylistId], references: [id], onDelete: Cascade)
}

model PlaylistVote {
  id                  String   @id @default(cuid())
  publishedPlaylistId String
  userId              String
  createdAt           DateTime @default(now())

  publishedPlaylist PublishedPlaylist @relation(fields: [publishedPlaylistId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publishedPlaylistId, userId])
}

model SavedPlaylist {
  id                  String   @id @default(cuid())
  userId              String
  publishedPlaylistId String
  localPlaylistId     String?
  lastSyncedAt        DateTime @default(now())
  createdAt           DateTime @default(now())

  publishedPlaylist PublishedPlaylist @relation(fields: [publishedPlaylistId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publishedPlaylistId])
}

// status: "PENDING" | "ACCEPTED" | "DECLINED"
model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}
