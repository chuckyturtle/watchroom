# ─── Base de datos PostgreSQL (gratis en neon.tech) ───────────────────────────
# 1. Crea cuenta en https://neon.tech (gratis)
# 2. Crea un proyecto → copia las dos URLs que aparecen
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Cadena aleatoria larga — puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-larga"

# ─── URL de tu app ─────────────────────────────────────────────────────────────
# Local:      http://localhost:3000
# Producción: https://tu-app.onrender.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Email (para enviar correos de bienvenida y recuperación) ──────────────────
# Usa Gmail + contraseña de aplicación:
# 1. Activa verificación en 2 pasos en tu Gmail
# 2. Ve a: https://myaccount.google.com/apppasswords
# 3. Genera una contraseña de aplicación y pégala aquí
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# ─── Twitch (opcional — para buscar streams en Twitch) ────────────────────────
# Gratis en: https://dev.twitch.tv/console → Register Your Application
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ─── YouTube Data API v3 (para charts reales actualizados a diario) ───────────
# 1. Ve a https://console.cloud.google.com
# 2. Crea un proyecto (o usa uno existente)
# 3. Activa "YouTube Data API v3" en APIs & Services → Library
# 4. Ve a APIs & Services → Credentials → + Create Credentials → API Key
# 5. (Opcional) Restringe la key a YouTube Data API v3
YOUTUBE_API_KEY=""

# ─── Billboard Charts (RapidAPI) ───────────────────────────────────────────────
# 1. Crea cuenta en https://rapidapi.com
# 2. Suscríbete en: https://rapidapi.com/sharmadhirajnp2/api/billboard-charts-api
# 3. Copia tu RapidAPI Key desde el dashboard (aplica a todas las APIs de RapidAPI)
# Charts disponibles: hot-100, hot-rap-songs, hot-latin-songs, dance-electronic-songs,
#   hot-rock-and-alternative-songs, hot-r-b-hip-hop-songs, pop-airplay,
#   latin-pop-airplay, regional-mexican-airplay
RAPIDAPI_KEY=""

# ─── NOTA: Sin estas keys el sistema usa Invidious (YouTube proxy gratuito) ───
# Con ambas keys: Billboard → busca video oficial en YouTube (máxima precisión)
# Solo YOUTUBE_API_KEY: busca por género ordenado por reproducciones en YouTube
# Sin keys: Invidious (fallback automático, no requiere configuración)
